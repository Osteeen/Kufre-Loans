# ============================================================
# Kufre Loans — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/kufre_db

# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# Email (SMTP — works with Gmail, SendGrid, Mailgun, etc.)
# For Gmail: use an App Password (not your account password)
# ------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
SUPPORT_EMAIL=support@kufre.com

# ------------------------------------------------------------
# Client URL (for CORS, password reset links, email buttons)
# ------------------------------------------------------------
CLIENT_URL=http://localhost:5173

# ------------------------------------------------------------
# Bank API (Providus Bank — currently stubbed)
# Replace with real credentials when Providus onboarding is complete.
# ------------------------------------------------------------
BANK_API_BASE_URL=https://api.providusbank.com/v1
BANK_CLIENT_ID=your_providus_client_id
BANK_CLIENT_SECRET=your_providus_client_secret
CORPORATE_ACCOUNT_NUMBER=0000000000

# ------------------------------------------------------------
# Revenue / Commission
# Decimal fraction of disbursed amount logged as platform revenue.
# e.g. 0.01 = 1% commission per loan disbursed.
# ------------------------------------------------------------
COMMISSION_RATE=0.01
